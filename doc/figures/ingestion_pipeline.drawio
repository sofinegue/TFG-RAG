        <mxCell id="a_c3i3" value="indexer (datasource)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;" edge="1" source="c3" target="i3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Step 5: AI Search -->
        <mxCell id="i1" value="&lt;b&gt;Azure AI Search&lt;/b&gt;&lt;br&gt;index-cvs&lt;br&gt;BM25 + HNSW vector + Semantic&lt;br&gt;filtros: chunk_type · sourceLanguage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
