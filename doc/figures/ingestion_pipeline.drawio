<mxfile host="app.diagrams.net">
  <diagram id="pipeline" name="Ingestion Pipeline">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1280" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Pipeline de Ingesta Documental" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="8" width="1080" height="28" as="geometry" />
        </mxCell>

        <!-- Column headers -->
        <mxCell id="ch1" value="CVs (JSON sintéticos)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="20" y="45" width="320" height="36" as="geometry" />
        </mxCell>
        <mxCell id="ch2" value="Wikipedia (JSON)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="45" width="320" height="36" as="geometry" />
        </mxCell>
        <mxCell id="ch3" value="Legislación UE (PDF)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="940" y="45" width="320" height="36" as="geometry" />
        </mxCell>

        <!-- Step 1: Blob Storage -->
        <mxCell id="b1" value="&lt;b&gt;Azure Blob Storage&lt;/b&gt;&lt;br&gt;data/cvs/{es,en}/cv_XXX.json&lt;br&gt;300 CVs × 2 idiomas&lt;br&gt;generate_cvs.py (plantillas Python)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="100" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="&lt;b&gt;Azure Blob Storage&lt;/b&gt;&lt;br&gt;data/wikipedia/{es,en}/json/*.json&lt;br&gt;Wikipedia API + Selenium (cookies Edge)&lt;br&gt;categorías: literatura, escritores, novelas…" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="100" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="&lt;b&gt;Azure Blob Storage&lt;/b&gt;&lt;br&gt;data/eu/{es,en,fr,pt,it}/*.pdf&lt;br&gt;EUR-Lex + Selenium (WAF bypass)&lt;br&gt;5 idiomas, series L del Diario Oficial" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="100" width="320" height="70" as="geometry" />
        </mxCell>

        <!-- Arrows B -> P -->
        <mxCell id="a_b1p1" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="b1" target="p1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_b2p2" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="b2" target="p2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_b3p3" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="b3" target="p3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Step 2: Chunking -->
        <mxCell id="p1" value="&lt;b&gt;doc_chunking_cvs.py&lt;/b&gt;&lt;br&gt;JSON → CVProcessor&lt;br&gt;3 chunks semánticos por CV&lt;br&gt;(experience · education · skills)&lt;br&gt;chunk_type como metadato filtrable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="220" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;doc_chunking_wiki.py&lt;/b&gt;&lt;br&gt;JSON text → Markdown (== → ##)&lt;br&gt;→ MarkdownHeaderTextSplitter&lt;br&gt;→ merge/split por umbral de tokens&lt;br&gt;sections como metadato jerárquico" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="220" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;doc_chunking_eu.py&lt;/b&gt;&lt;br&gt;PDF → Azure Document Intelligence&lt;br&gt;(prebuilt-layout → Markdown)&lt;br&gt;→ MarkdownHeaderTextSplitter&lt;br&gt;→ merge/split por umbral de tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="220" width="320" height="80" as="geometry" />
        </mxCell>

        <!-- Arrows P -> Emb -->
        <mxCell id="a_p1e" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p1" target="emb" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_p2e" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p2" target="emb" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_p3e" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p3" target="emb" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Step 3: Embedding (shared) -->
        <mxCell id="emb" value="&lt;b&gt;Azure OpenAI — text-embedding-ada-002&lt;/b&gt;   ·   vector[1536]   ·   generado por chunk antes de subir a Cosmos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="375" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Arrows Emb -> Cosmos -->
        <mxCell id="a_ec1" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="emb" target="c1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_ec2" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="emb" target="c2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_ec3" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="emb" target="c3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Step 4: Cosmos DB -->
        <mxCell id="c1" value="&lt;b&gt;Cosmos DB&lt;/b&gt;&lt;br&gt;container: Chunks-CVs&lt;br&gt;DocEntity + isDeleted (borrado lógico)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="480" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="&lt;b&gt;Cosmos DB&lt;/b&gt;&lt;br&gt;container: Chunks-Wiki&lt;br&gt;DocEntity + isDeleted (borrado lógico)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="480" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="&lt;b&gt;Cosmos DB&lt;/b&gt;&lt;br&gt;container: Chunks-EU&lt;br&gt;DocEntity + isDeleted (borrado lógico)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="480" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- Arrows Cosmos -> AI Search -->
        <mxCell id="a_c1i1" value="indexer (datasource)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;" edge="1" source="c1" target="i1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
