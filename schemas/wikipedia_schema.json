    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "enum": ["es", "en"]
    },
    "pageid": {
      "type": "integer"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "text": {
      "type": "string",
      "minLength": 1
    }
  }
}